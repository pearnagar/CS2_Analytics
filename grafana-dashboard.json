{
  "title": "CS2 Analytics API",
  "uid": "cs2-analytics-api",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"cs2-api-service\"}[5m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 request latency (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"cs2-api-service\"}[5m])) by (le, handler))",
          "legendFormat": "{{handler}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error rate (5xx / total)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"cs2-api-service\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"cs2-api-service\"}[5m]))",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  }
}
